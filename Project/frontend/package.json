{
  "name": "vue-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "docker-dev": "vite --host 0.0.0.0 --port 3000",
    "dev": "vite --host --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .vue,.js",
    "lint:fix": "eslint . --ext .vue,.js --fix",
    "format": "prettier --write \"src/**/*.{js,vue}\""
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.3.4",
    "terser": "^5.20.0",
    "vite": "^4.4.9",
    "vitest": "^0.34.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^22.0.0",
    "@vitest/coverage-v8": "^0.34.0",
    "msw": "^1.2.0",
    "eslint": "^8.45.0",
    "prettier": "^3.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^13.2.0"
  }

}

